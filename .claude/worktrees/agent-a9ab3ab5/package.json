{
  "name": "terminaldeck",
  "version": "1.0.0",
  "description": "Web-based persistent terminal dashboard powered by tmux",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "test": "mocha --recursive 'server/**/*.test.js' 'client/**/*.test.js' --exit",
    "test:integration": "mocha 'test/**/*.test.js' --exit --timeout 30000",
    "test:all": "mocha --recursive 'server/**/*.test.js' 'client/**/*.test.js' 'test/**/*.test.js' --exit --timeout 30000",
    "build:codemirror": "esbuild scripts/bundle-codemirror.js --bundle --format=iife --minify --outfile=client/vendor/codemirror6.bundle.js"
  },
  "dependencies": {
    "fuse.js": "^7.1.0",
    "node-pty": "1.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.17",
    "@replit/codemirror-minimap": "^0.5.2",
    "@replit/codemirror-vim": "^6.3.0",
    "chai": "^4.5.0",
    "codemirror": "^6.0.2",
    "esbuild": "^0.27.3",
    "jsdom": "^28.1.0",
    "mocha": "^10.8.0",
    "sinon": "^19.0.0"
  }
}
