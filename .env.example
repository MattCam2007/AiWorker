# TerminalDeck Environment Configuration
# Copy this file to .env and adjust values for your system:
#   cp .env.example .env

# User/Group ID - match your host user to avoid permission issues
# Run `id` to find your UID and GID
PUID=1000
PGID=1000

# Port to expose TerminalDeck on
TERMINALDECK_PORT=3000

# Host directory to mount as /workspace inside the container
WORKSPACE_PATH=/home/youruser/Projects

# (Optional) SSH agent forwarding - mount the agent socket, NEVER mount key files
# The agent performs signing in host memory - private keys never enter the container.
# For extra security, use `ssh-add -c` on the host for per-use confirmation popups.
#SSH_AUTH_SOCK=/run/user/1000/keyring/ssh

# (Optional) Claude Code config - uncomment to persist Claude sessions
#CLAUDE_CONFIG_PATH=/home/youruser/.claude
#CLAUDE_JSON_PATH=/home/youruser/.claude.json
